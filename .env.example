# ──────────────────────────────────────────────────────────────────────────────
# MindVex Backend — Environment Variables
#
# These variable NAMES are identical to those set in Render (production).
# Only the VALUES change between local and prod.
# Never put prod secrets here — use Render's Environment Variables panel.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Profile ──────────────────────────────────────────────────────────────────
# "dev" enables verbose SQL/logging. "prod" for production.
SPRING_PROFILES_ACTIVE=dev

# ─── Database ─────────────────────────────────────────────────────────────────
# Full JDBC URL — same variable name as Render.
# Render injects the Railway/postgres URL automatically.
DATABASE_URL=jdbc:postgresql://localhost:5432/mindvex?sslmode=disable&user=postgres&password=your_password

# ─── GitHub OAuth2 ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-mindvex-ai-platform-2026

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. Add localhost origins for local dev.
# Render value: http://localhost:5173,https://mindvex-editor.pages.dev
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://mindvex-editor.pages.dev

# ─── OAuth2 Authorized Redirect URIs ─────────────────────────────────────────
# Comma-separated list. First URI is the fallback default.
# Render value: https://mindvex-editor.pages.dev/auth/callback
APP_OAUTH2_AUTHORIZED_REDIRECT_URIS=http://localhost:5173/auth/callback,https://mindvex-editor.pages.dev/auth/callback

# ─── Git Repo Cache Dir ───────────────────────────────────────────────────────
# Where JGit clones repos locally. /tmp works for both local and Render.
GIT_REPO_BASE_DIR=/tmp/mindvex-repos
